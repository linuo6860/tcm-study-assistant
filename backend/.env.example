# Local or cloud storage paths. On Render, keep the defaults for a first test,
# or point these to a persistent disk mount if you add one.
TCM_STORAGE_DIR=/tmp/tcm-study-assistant
TCM_UPLOAD_DIR=/tmp/tcm-study-assistant/uploads

# Your GitHub Pages origin. Origin includes scheme + host, not the path.
# Example: https://linuo6860.github.io
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://linuo6860.github.io

# Optional: override the textbook JSON path.
# TEXTBOOK_JSON_PATH=/path/to/sample_tcm_textbook.json

